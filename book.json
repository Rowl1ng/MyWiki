{
    "links": {
        "sidebar": {
            "Home": "http://rowl1ng.com",
            "Blog": "http://rowl1ng.com/blog"
        }
    },
    "plugins": [
                "theme-hqbook",
                "chapter-fold",
                "katex",
                "expandable-chapters-small",
                "todo",
                "donate",
                "favicon",
                "code",
                "advanced-emoji",
                "-lunr", "-search", "search-pro"],
    "pluginsConfig": {
            "theme-hqbook": {
                "favicon": "https://rowl1ng.com/blog/style/favicons/favicon.ico",
                "logo":"https://rowl1ng.com/blog/style/images/logo-rowl1ng.png",
                "search-placeholder":"Search",
                "copyButtons": true,
                "copyLines": true,
                "dragSplitter": true,
                "hide-elements": [
                    ".summary .gitbook-link"
                ]
            },
            "prism": {
                "css": [
                  "gitbook-plugin-theme-hqbook/_themes/prism-vs.css"
                ]
              },
            "donate": {
                   "wechat":"http://static.zybuluo.com/sixijinling/3mhqbsdz9a24mrhdgj348e9x/image_1cfuoqam86g5197d1cnt12k211s823.png",
                        "alipay": "http://static.zybuluo.com/sixijinling/3fnxywa4rs75f25kinu5ahnn/image_1cfuh8j65mc41k3q28cp431679.png",
                        "title": "",
                        "button": "Donate",
                        "alipayText": "支付宝打赏",
                        "wechatText": "微信打赏"
                      },
            "anchor-navigation-ex": {
                        "isRewritePageTitle": true,
                        "isShowTocTitleIcon": true,
                        "tocLevel1Icon": "fa fa-hand-o-right",
                        "tocLevel2Icon": "fa fa-hand-o-right",
                        "tocLevel3Icon": "fa fa-hand-o-right"
                        },
            "insert-logo": {
                "url": "https://rowl1ng.com/blog/style/images/logo-rowl1ng.png",
                "style": "background: none; max-width: 100px"
            },
            "lightbox": {
                "includeJQuery": false,
                "sameUuid": true,
                "options": {
                    "resizeDuration": 500,
                    "wrapAround": false
                }
            }
                }
}
