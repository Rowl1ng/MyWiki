#!/bin/bash
set -e  # 出错时退出

# 1. 确认当前在 source 分支
current_branch=$(git branch --show-current)
if [ "$current_branch" != "source" ]; then
    echo "❌ 请先切换到 source 分支再运行此脚本"
    exit 1
fi

# 2. 清理旧构建
rm -rf _book

# 3. 构建 GitBook/HonKit
echo "📚 正在构建 GitBook..."
npx honkit build

# 4. 切换到临时部署目录
cd _book

# 5. 初始化新的 Git 仓库
git init
git checkout -b master
git add .
git commit -m "Deploy GitBook to GitHub Pages"

# 6. 推送到远程 master 分支
# ⚠️ 替换成你的仓库地址
git remote add origin git@github.com:Rowl1ng/MyWiki.git
git push --force origin master

# 7. 返回原目录
cd ..

echo "✅ 部署完成！已推送到 master 分支。"
